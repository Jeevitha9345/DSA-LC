class Solution {
    public double findMaxAverage(int[] nums, int k) {
        double ans=0,res=0;
        if(nums.length==1 && k==1){
            return nums[0];
        }
        for(int i=0;i<k;i++){
            res+=nums[i];
        }
        ans=res/k;
        for(int i=k;i<nums.length;i++){
            res=res-nums[i-k]+nums[i];
            double avg=res/k;
            if(ans<avg){
                ans=avg;
            }
        }return ans;
    }
}
